{
  "name": "harness-automation",
  "version": "1.0.3",
  "description": "Harness Automation System - MCP Server for automated constraint configuration",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && cp src/rules.json dist/rules.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@typescript-eslint/typescript-estree": "^8.59.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
